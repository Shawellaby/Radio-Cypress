<Window x:Class="RadioCypress.StationEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="Black"
        Foreground="White"
        Title="Edit Stations"
        Height="520"
        Width="850"
        MinHeight="420"
        MinWidth="720"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Border BorderBrush="CornflowerBlue"
            BorderThickness="2"
            Padding="14">
        <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top"
                       Text="Edit Stations"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Aquamarine"
                       Margin="0,0,0,12" />

            <TextBlock DockPanel.Dock="Top"
                       Text="Edit station presets below. Station numbers must be unique and between 1 and 9."
                       Foreground="#CCCCCC"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">

                <Button Content="Add"
                        Width="90"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="Add_Click"
                        Background="#1E1E1E"
                        Foreground="White"
                        BorderBrush="CornflowerBlue"
                        BorderThickness="1"
                        FontWeight="SemiBold" />

                <Button Content="Delete"
                        Width="90"
                        Height="32"
                        Margin="0,0,20,0"
                        Click="Delete_Click"
                        Background="#1E1E1E"
                        Foreground="White"
                        BorderBrush="CornflowerBlue"
                        BorderThickness="1"
                        FontWeight="SemiBold" />

                <Button Content="Save"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="Save_Click"
                        Background="#1E1E1E"
                        Foreground="White"
                        BorderBrush="Aquamarine"
                        BorderThickness="1"
                        FontWeight="SemiBold" />

                <Button Content="Cancel"
                        Width="100"
                        Height="32"
                        IsCancel="True"
                        Click="Cancel_Click"
                        Background="#1E1E1E"
                        Foreground="White"
                        BorderBrush="CornflowerBlue"
                        BorderThickness="1"
                        FontWeight="SemiBold" />
            </StackPanel>

            <DataGrid x:Name="StationsGrid"
                      ItemsSource="{Binding Stations}"
                      SelectedItem="{Binding SelectedStation, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowBackground="#121212"
                      AlternatingRowBackground="#1A1A1A"
                      Background="#0D0D0D"
                      Foreground="White"
                      BorderBrush="#333333"
                      HorizontalGridLinesBrush="#333333"
                      VerticalGridLinesBrush="#333333"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#202020" />
                        <Setter Property="Foreground" Value="Aquamarine" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="BorderBrush" Value="#333333" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Padding" Value="8,6" />
                    </Style>

                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="#222222" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="CaretBrush" Value="White" />
                        <Setter Property="BorderBrush" Value="CornflowerBlue" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"
                                        Binding="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70" />

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Width="180" />

                    <DataGridTextColumn Header="Stream URL"
                                        Binding="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />

                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>