<Window x:Class="Shawellaby.RadioCypress.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shawellaby.RadioCypress"
        mc:Ignorable="d"
        WindowStyle="SingleBorderWindow"
        Title="Radio Cypress" Height="250" Width="650"
        Background="Black"
        Padding="0"
        Margin="0"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- <RowDefinition Height="*" /> -->
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- <Image Grid.Row="0" Name="StationLogo" Source="Content/startup.jpg" Margin="2" /> -->

        <Canvas x:Name="VisualizationCanvas"
                Grid.Row="0"
                Margin="10,10,10,10"
                Background="#111111" />

        <Grid Grid.Row="1"
              Margin="5,0,5,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

           <Border Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="12,4"
                    Margin="0,0,5,0"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="#3A3A3A"
                    Background="#0D0D0D">
                <Border.Effect>
                    <DropShadowEffect Color="#B7FF00"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.55" />
                </Border.Effect>

                <Grid x:Name="MutinPanel"
                      HorizontalAlignment="Stretch"
                      RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1A1A1A" Offset="0.0" />
                            <GradientStop Color="#090909" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBlock Foreground="CornflowerBlue"
                                   Background="Transparent"
                                   Opacity="0.12"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="88888888">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="CornflowerBlue"
                                                  BlurRadius="4"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="IsMutedLabel"
                                   Foreground="CornflowerBlue"
                                   Background="Transparent"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   Opacity=".65"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="MUTE">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="CornflowerBlue"
                                                  BlurRadius="28"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="12,4"
                    Margin="3,0,3,0"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="#3A3A3A"
                    Background="#0D0D0D">
                <Border.Effect>
                    <DropShadowEffect Color="#B7FF00"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.55" />
                </Border.Effect>

                <Grid x:Name="StationPanel"
                      HorizontalAlignment="Stretch"
                      RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1A1A1A" Offset="0.0" />
                            <GradientStop Color="#090909" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBlock Foreground="#D9FF5A"
                                   Background="Transparent"
                                   Opacity="0.12"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="8888888888888888888888">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#3eff8c"
                                                  BlurRadius="4"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="StationName"
                                   Foreground="#3eff8c"
                                   Background="Transparent"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   Opacity=".65"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="NONE">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#3eff8c"
                                                  BlurRadius="28"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>




            <Border Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="12,4"
                    Margin="5,0,0,0"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="#3A3A3A"
                    Background="#0D0D0D">
                <Border.Effect>
                    <DropShadowEffect Color="#B7FF00"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.55" />
                </Border.Effect>

                <Grid x:Name="RecordingPanel"
                      HorizontalAlignment="Stretch"
                      RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1A1A1A" Offset="0.0" />
                            <GradientStop Color="#090909" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBlock Foreground="#FF4E1D"
                                   Background="Transparent"
                                   Opacity="0.12"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="888888888">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF4E1D"
                                                  BlurRadius="4"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="IsRecordingLabel"
                                   Foreground="#FF4E1D"
                                   Background="Transparent"
                                   FontFamily="../Content/#Digital-7 Mono"
                                   Opacity=".65"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="RECORDING">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#ff0000"
                                                  BlurRadius="28"
                                                  ShadowDepth="0"
                                                  Opacity="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>


        </Grid>
    </Grid>

</Window>