<Window x:Class="RadioCypress.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Black"
        Foreground="White"
        Title="Help"
        Height="650"
        Width="420"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Border BorderBrush="CornflowerBlue"
            BorderThickness="2"
            Padding="14"
            Margin="0">
        <StackPanel>
            <TextBlock Text="Help"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Aquamarine"
                       Margin="0,0,0,14" />

            <TextBlock Text="Keyboard shortcuts"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="H - Show this help window"
                       Margin="0,0,0,4" />
            <TextBlock Text="ENTER - Show station selection window"
                       Margin="0,0,0,4" />
            <TextBlock Text="Ctrl+E - Edit stations"
                       Margin="0,0,0,4" />
            <TextBlock Text="1-9 / Numpad 1-9 - Select station"
                       Margin="0,0,0,4" />
            <TextBlock Text="M - Mute / unmute"
                       Margin="0,0,0,4" />
            <TextBlock Text="R - Start / stop recording"
                       Margin="0,0,0,4" />
            <TextBlock Text="Q - Quit application"
                       Margin="0,0,0,14" />

            <TextBlock Text="Visualizations" FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="E - Equalizer"
                       Margin="0,0,0,4" />
            <TextBlock Text="P - Psychedelic"
                       Margin="0,0,0,4" />
            <TextBlock Text="W - Wave"
                       Margin="0,0,0,4" />
            <TextBlock Text="L - LED WOPR"
                       Margin="0,0,0,4" />
            <TextBlock Text="T - Ethereal"
                       Margin="0,0,0,4" />
            <TextBlock Text="O - Oscilloscope"
                       Margin="0,0,0,14" />

            <TextBlock Text="Station Listing"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <ItemsControl ItemsSource="{Binding Stations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Number}" />
                            <Run Text="  " />
                            <Run Text="{Binding Name}" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Close"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    IsDefault="True"
                    IsCancel="True"
                    Click="Close_Click"
                    Background="#1E1E1E"
                    Foreground="White"
                    BorderBrush="CornflowerBlue"
                    BorderThickness="1"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#1E1E1E" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="CornflowerBlue" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="CornflowerBlue" />
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="Aquamarine" />
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock FontSize="10"
                       Foreground="#444444"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,15">
                <Run Text="© " />
                <Run Text="{Binding CopyrightYear, Mode=OneTime}" />
                <Run Text="- Shawellaby Software  |  https://github.com/Shawellaby" />
            </TextBlock>
        </StackPanel>
    </Border>
</Window>